# این فایل را کپی کنید و نام آن را .env بگذارید، سپس مقداردهی کنید.
# cp .env.example .env

# --- هویت ربات (Bot Token رسمی روبیکا) ---
# توکن را از پنل مدیریت بات‌های روبیکا (@BotFather یا مشابه) دریافت کنید.
# هیچ لاگین با شماره تلفن یا کد تایید لازم نیست.
BOT_TOKEN=

# --- دسترسی‌ها ---
# شناسه (GUID) حساب مالک اصلی ربات را اینجا قرار دهید.
OWNER_ID=

# اختیاری: شناسه سایر Creator های مورد اعتماد (سطح دسترسی داخلی LeoBot)، با کاما جدا شوند
CREATOR_IDS=

# اختیاری: شناسه‌ی سایر مدیرانی که اجازه‌ی باز کردن «پنل ادمین» در PV را دارند،
# با کاما جدا شوند. مالک (OWNER_ID) همیشه و به‌صورت خودکار دسترسی دارد.
PANEL_ADMIN_IDS=

# --- رمز پنل ادمین ---
# طبق نیاز پروژه، رمز پیش‌فرض پنل باید دقیقاً همین مقدار باشد.
# فقط یکی از دو مقدار زیر را پر کنید (ترجیحاً ADMIN_PASSWORD_HASH برای امنیت بیشتر).
ADMIN_PASSWORD=GG777mahi
# ADMIN_PASSWORD_HASH=

# --- دیتابیس / لاگ ---
DATABASE_FILE=leobot.db
LOG_FILE=leobot.log
LOG_LEVEL=INFO

# --- تنظیمات امنیتی پیش‌فرض ---
DEFAULT_WARN_LIMIT=3
DEFAULT_FLOOD_LIMIT=6
DEFAULT_FLOOD_WINDOW=8
DEFAULT_DUPLICATE_LIMIT=3

PANEL_MAX_LOGIN_ATTEMPTS=3
PANEL_LOCKOUT_SECONDS=300

# --- اتصال / اتصال مجدد ---
RECONNECT_DELAY_SECONDS=5
RECONNECT_MAX_DELAY_SECONDS=60
